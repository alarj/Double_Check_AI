## Oracle wallet setup:
## 1) Unzip wallet to: ~/Oracle/Wallet_WOQC8AR450A6CUM0
## 2) Ensure this folder contains tnsnames.ora and sqlnet.ora
## 3) Set ORACLE_DSN to a TNS alias from tnsnames.ora (for example: <alias>_high)
## 4) ORACLE_ENABLED controls backend choice:
##    - yes: use Oracle backend
##    - no (or missing .env): use local sqlite/chroma backend

ORACLE_ENABLED=yes
ORACLE_USER=AI_APP
ORACLE_PASSWORD=CHANGE_ME
ORACLE_DSN=YOUR_TNS_ALIAS_HIGH
ORACLE_CONFIG_DIR=~/Oracle/Wallet_WOQC8AR450A6CUM0
ORACLE_WALLET_LOCATION=~/Oracle/Wallet_WOQC8AR450A6CUM0
ORACLE_WALLET_PASSWORD=CHANGE_ME

ORACLE_EMBED_MODEL=bge-m3
ORACLE_OLLAMA_URL=http://ollama:11434
ORACLE_EMBED_BATCH_SIZE=16
